# ============================================
# XRP Trading Bot Configuration
# ============================================

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# BitOasis API (Required for live trading)
BITOASIS_API_KEY=your_api_key_here
BITOASIS_API_SECRET=your_api_secret_here

# Trading Mode
# Set to 'false' for live trading (CAUTION!)
PAPER_TRADING=true

# Starting Capital (USD)
STARTING_CAPITAL_USD=500

# Database
DATABASE_PATH=./data/trading.db
